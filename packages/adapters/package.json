{
  "name": "@piggy/adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    },
    "./aave.js": {
      "import": "./dist/aave.js",
      "types":  "./dist/aave.d.ts"
    },
    "./mento.js": {
      "import": "./dist/mento.js",
      "types":  "./dist/mento.d.ts"
    }
  },
  "scripts": {
    "build":     "tsc",
    "typecheck": "tsc --noEmit",
    "dev":       "tsc --watch"
  },
  "dependencies": {
    "@piggy/config": "workspace:*",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
