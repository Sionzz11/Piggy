{
  "name": "@piggy/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./decisionEngine.js": {
      "import": "./dist/decisionEngine.js",
      "types": "./dist/decisionEngine.d.ts"
    },
    "./skills/index.js": {
      "import": "./dist/skills/index.js",
      "types": "./dist/skills/index.d.ts"
    },
    "./intelligence/index.js": {
      "import": "./dist/intelligence/index.js",
      "types": "./dist/intelligence/index.d.ts"
    },
    "./skills/safety/index.js": {
      "import": "./dist/skills/safety/index.js",
      "types": "./dist/skills/safety/index.d.ts"
    },
    "./skills/intelligence/index.js": {
      "import": "./dist/skills/intelligence/index.js",
      "types": "./dist/skills/intelligence/index.d.ts"
    },
    "./skills/safety/riskScoringEngine.js": {
      "import": "./dist/skills/safety/riskScoringEngine.js",
      "types": "./dist/skills/safety/riskScoringEngine.d.ts"
    },
    "./skills/intelligence/protocolHealthMonitor.js": {
      "import": "./dist/skills/intelligence/protocolHealthMonitor.js",
      "types": "./dist/skills/intelligence/protocolHealthMonitor.d.ts"
    },

  "./intelligence/goalFeasibility.js": {
  "import": "./dist/intelligence/goalFeasibility.js",
  "types": "./dist/intelligence/goalFeasibility.d.ts"
},
"./intelligence/paceTracking.js": {
  "import": "./dist/intelligence/paceTracking.js",
  "types": "./dist/intelligence/paceTracking.d.ts"
}
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@piggy/config": "workspace:*",
    "@piggy/shared": "workspace:*",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts"
    ],
    "exclude": [
      "**/node_modules/**",
      "**/dist/**"
    ]
  }
}