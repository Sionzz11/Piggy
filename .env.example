# ─────────────────────────────────────────────────────────────────────────────
# PiggySentinel — .env Production
# ─────────────────────────────────────────────────────────────────────────────

# ── App Environment ───────────────────────────────────────────────────────────
APP_ENV=prod
NODE_ENV=production
ENABLE_MAINNET_EXECUTION=true
NEXT_PUBLIC_APP_ENV=prod

# ── RPC ───────────────────────────────────────────────────────────────────────
CELO_RPC_URL_MAINNET=https://forno.celo.org
# Frontend RPC (used by wallet clients in browser)
NEXT_PUBLIC_CELO_RPC_URL_MAINNET=https://forno.celo.org
NEXT_PUBLIC_CELO_RPC_URL_SEPOLIA=https://forno.celo-sepolia.celo.org

# ── Wallets ───────────────────────────────────────────────────────────────────
DEPLOYER_ADDRESS=0x_YOUR_DEPLOYER_ADDRESS
AGENT_SIGNER_PRIVATE_KEY=0x_YOUR_AGENT_PRIVATE_KEY
AGENT_SIGNER_ADDRESS=0x_YOUR_AGENT_ADDRESS
TREASURY_ADDRESS=0x_YOUR_TREASURY_ADDRESS

# ── Contracts (fill after forge deploy) ───────────────────────────────────────
SENTINEL_EXECUTOR_ADDRESS=0x_FILL_AFTER_DEPLOY
AAVE_ADAPTER_ADDRESS=0x_FILL_AFTER_DEPLOY
MENTO_ADAPTER_ADDRESS=0x_FILL_AFTER_DEPLOY
UNISWAP_ADAPTER_ADDRESS=0x_FILL_AFTER_DEPLOY
AAVE_ORACLE_WRAPPER_ADDRESS=0x_FILL_AFTER_DEPLOY
NEXT_PUBLIC_SENTINEL_EXECUTOR_ADDRESS=0x_FILL_AFTER_DEPLOY

# ── Protocol Addresses (Celo Mainnet — confirmed) ─────────────────────────────
AAVE_POOL_ADDRESS=0x3E59A31363E2ad014dcbc521c4a0d5757d9f3402
UNISWAP_PM_ADDRESS=0x3d2bD0e15829AA5C362a4144FdF4A1112fa29B5c

# ── Token Addresses (Celo Mainnet — confirmed) ────────────────────────────────
NEXT_PUBLIC_USDM_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
NEXT_PUBLIC_USDT_ADDRESS=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e

# ── Aave aToken Addresses (Celo Mainnet — confirmed) ──────────────────────────
A_USDC_ADDRESS=0xFF8309b9e99bfd2D4021bc71a362aBD93dBd4785
A_USDT_ADDRESS=0xDeE98402A302e4D707fB9bf2bac66fAEEc31e8Df
A_USDM_ADDRESS=0xBba98352628B0B0c4b40583F593fFCb630935a45
NEXT_PUBLIC_A_USDC_ADDRESS=0xFF8309b9e99bfd2D4021bc71a362aBD93dBd4785
NEXT_PUBLIC_A_USDT_ADDRESS=0xDeE98402A302e4D707fB9bf2bac66fAEEc31e8Df
NEXT_PUBLIC_A_USDM_ADDRESS=0xBba98352628B0B0c4b40583F593fFCb630935a45

# ── Uniswap Pool ──────────────────────────────────────────────────────────────
UNISWAP_USDC_WETH_POOL=0x2d70Cbabf4D8e61d5317B62cBF8C90B342b7d2e2

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/piggysentinel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Privy (auth) ──────────────────────────────────────────────────────────────
# Get from: https://dashboard.privy.io → project → Settings → API Keys
PRIVY_APP_ID=clx_YOUR_PRIVY_APP_ID
PRIVY_APP_SECRET=YOUR_PRIVY_APP_SECRET
NEXT_PUBLIC_PRIVY_APP_ID=clx_YOUR_PRIVY_APP_ID

# ── AI ────────────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-YOUR_API_KEY
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Internal API Secret ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=YOUR_32_CHAR_SECRET

# ── API & Frontend URLs ───────────────────────────────────────────────────────
PIGGY_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/PiggySentinelBot

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# ── Security ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Gas Config ────────────────────────────────────────────────────────────────
MAX_GAS_PRICE_GWEI=50
MAX_GAS_COST_USD=0.50
TYPICAL_REBALANCE_GAS=300000
MAX_GAS_PER_TX=800000

# ── APY Fallback (used if subgraph is down) ───────────────────────────────────
APY_USDM=1.07
APY_USDC=2.61
APY_USDT=8.89

# ── Price Fallback ────────────────────────────────────────────────────────────
ETH_PRICE_USD=3000

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_VOLATILITY_PCT=15.0

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set true untuk bypass gas/amount guardrails — untuk demo dengan portfolio kecil ($10)
# JANGAN aktifkan di production
DEMO_MODE=false